{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/window"
    ],
    "modules-center": [],
    "modules-right": [
        "disk",
        "memory",
        "network",
        "pulseaudio",
        "custom/weather",
        "clock"
    ],

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/window": {
        "max-length": 50,
        "format": " | {title}"
    },

    "disk": {
        "interval": 30,
        "format": "DISK {percentage_used}%",
        "path": "/"
    },

    "memory": {
        "format": "RAM {used:0.1f}G"
    },

    "network": {
        "interval": 5,
        "format-wifi": "WLAN {ipaddr} {signalStrength}%",
        "format-ethernet": "ETH {ipaddr}",
        "format-disconnected": "OFFLINE"
    },

    "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-bluetooth": "{icon} (BT) {volume}%",
            "format-muted": "Muted",
            "format-icons": {
                "headphone": "Headphone",
                "hands-free": "Handsfree",
                "headset": "Headset",
                "phone": "Telphone",
                "portable": "Portable",
                "car": "Car",
                "default": ["Speakers"]
            },
            "on-click": "~/.config/waybar/audio.sh",
            "on-click-right": "pavucontrol"
        },

    "custom/weather": {
        "exec": "~/.config/waybar/weather.sh",
        "interval": "once",
        "signal": 8,
        "on-click": "pkill -RTMIN+8 waybar",
        "format": "{}"
    },

    "clock": {
        "format": "󰃭 {:%a %d/%m/%Y   %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "timezone": "America/Argentina/Buenos_Aires"
    }
}
